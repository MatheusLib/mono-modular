[Unit]
Description=mono-modular API
After=network.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/home/ec2-user/mono-modular
EnvironmentFile=/home/ec2-user/mono-modular/.env
ExecStart=/home/ec2-user/mono-modular/api
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
